{
  "compilerOptions": {
      "jsx": "react",
      "target": "ES2020",
      "lib": ["ES2021", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "types": ["vite/client"],
      "baseUrl": ".",
      "paths": {
      "@/*": [
          "src/*"
      ]
      },
      "moduleResolution": "bundler"
  },
  "include": [
      "src/**/*"
  ],
  "exclude": [
      "node_modules"
  ]
}